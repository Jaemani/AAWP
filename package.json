{
  "name": "adaptive-artifact-workflow-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "workflows/templates/*"
  ],
  "bin": {
    "awf": "./apps/cli/dist/index.js"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && npm run generate:schema",
    "typecheck": "tsc -b tsconfig.build.json --pretty false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "validate:heavy-spec": "tsx scripts/validate-heavy-spec.ts",
    "generate:schema": "tsx scripts/generate-schema.ts",
    "generate:heavy-spec-revision": "tsx scripts/generate-heavy-spec-revision.ts",
    "generate:heavy-spec-role-comparison": "tsx scripts/generate-heavy-spec-role-comparison.ts",
    "request:spec-to-demo": "node scripts/create-spec-to-demo-request.mjs",
    "studio": "node apps/studio/dist/server.js --catalog workflows/catalog.json --runs runs/history.jsonl --execution-root runs --demo-root runs --demo-source runs/{runId}/artifacts/demo",
    "studio:spec-to-demo": "npm run studio",
    "qa:demo-layout": "node scripts/qa-demo-layout.mjs",
    "migrate:runs": "node scripts/migrate-runs-to-root.mjs",
    "bench:direct": "tsx benchmarks/direct-v0/harness/run-direct.ts",
    "bench:direct:reverify": "tsx benchmarks/direct-v0/harness/reverify.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.52",
    "ajv": "8.20.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@playwright/test": "^1.61.1",
    "@temporalio/testing": "1.20.2",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "fast-check": "4.9.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
