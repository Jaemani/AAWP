  "interactions": {
    "affordances": [
      {
        "id": "admin-roster-builder.pickPolicyForPlan",
        "element": "OperationPlanPanel(planPolicyPick)",
        "trigger": "tap",
        "action": "setLocalState",
        "target": "operationPlanDraft.policyRef",
        "storeEffect": "none",
        "expected": "approvalStatus='approved'이고 lifecycleStatus='active'인 정책만 선택한다.",
        "resolution": { "kind": "demo-state", "target": "operationPlanDraft.policyRef" }
      },
      {
        "id": "admin-roster-builder.editOperationPlanDraft",
        "element": "OperationPlanPanel(planFields)",
        "trigger": "input",
        "action": "setLocalState",
        "target": "operationPlanDraft",
        "storeEffect": "none",
        "expected": "운영계획서 초안을 로컬 draft로 작성한다.",
        "resolution": { "kind": "demo-state", "target": "operationPlanDraft" }
      },
      {
        "id": "admin-roster-builder.evaluateRules",
        "element": "RosterBuilderPanel(evaluateCta)",
        "trigger": "tap",
        "action": "setLocalState",
        "target": "candidateRosterDraft",
        "storeEffect": "none",
        "expected": "선택된 PolicyCondition summary와 행정속성 평가 결과 projection으로 후보를 만든다. 이 단계는 권위 지급 기록을 만들지 않는다.",
        "resolution": { "kind": "demo-state", "target": "candidateRosterDraft" }
      },
      {
        "id": "admin-roster-builder.upload",
        "element": "RosterBuilderPanel(uploadCta)",
        "trigger": "tap",
        "action": "setLocalState",
        "target": "candidateRosterDraft.uploadFileRef",
        "storeEffect": "none",
        "expected": "external-ingest 파일 ref를 draft에 연결하고 중복·제외 사유 preview를 표시한다.",
        "resolution": { "kind": "demo-state", "target": "candidateRosterDraft.uploadFileRef" }
      },
      {
        "id": "admin-roster-builder.configureApproval",
        "element": "ApprovalPolicyPicker+ApproverSelector",
        "trigger": "tap",
        "action": "setLocalState",
        "target": "approvalDraft",
        "storeEffect": "none",
        "expected": "appliesTo='policy-approval', sourceAction='roster-approval' 결재정책, 승인자 후보, 결재선, opt-in SoD 결과를 구성한다.",
        "resolution": { "kind": "demo-state", "target": "approvalDraft" }
      },
      {
        "id": "admin-roster-builder.confirm",
        "element": "RosterBuilderPanel(confirmCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "roster-confirm-and-submit-approval",
        "storeEffect": "approvals.submitForApproval({subjectType:'roster',subjectRef:candidateRosterDraft.rosterId,sourceScreenId:'admin-roster-builder',sourceAction:'roster-approval',sourceActionAliases:['roster-approval'],requester:{identity:author.identity,title:author.title,jurisdiction:author.jurisdiction},appliesTo:'policy-approval',approvalPolicyRef,approverAssignments,signerBindings,sodPolicyResult,approvalContext:{operationPlanDraft,candidateRosterDraft,policyRef},onFinalApproved:{actionRefs:[{slice:'roster',action:'approveRoster',args:{rosterId:'$subjectRef',approvalId:'$approvalId',approvedAt:'$approvedAt'},idempotencyKey:'roster-approve:$subjectRef:$approvalId',onlyWhen:{approvalStatus:'approved',quorumSatisfied:true}},{slice:'payouts',action:'createDirectGrantRecordsFromRoster',args:{rosterId:'$subjectRef',policyRef:'$approvalContext.policyRef',approvalId:'$approvalId'},idempotencyKey:'direct-grants-from-roster:$subjectRef:$approvalId',onlyWhen:{approvalStatus:'approved',quorumSatisfied:true,payoutMethod:'direct-grant'}}]}})",
        "expected": "후보 명부를 결재 큐로 전달한다. 정족수 충족 후 approvals.runOnFinalApprovedOnce가 명부 승인과 direct-grant 지급 후처리를 한 번만 실행한다.",
        "resolution": { "kind": "demo-state", "target": "roster-confirm-and-submit-approval" }
      }
    ],
    "reachableStates": [
