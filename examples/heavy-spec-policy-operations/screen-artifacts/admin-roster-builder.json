  "screen": {
    "id": "admin-roster-builder",
    "route": "/admin/circulation/rosters/build",
    "surface": "관리 콘솔(웹)",
    "title": "대상 명부 확정 · 운영계획서(OperationPlan)",
    "purpose": "승인된 정책을 참조해 OperationPlan을 작성하고 후보 명부를 산출한다. 후보 명부 확정은 지급이 아니며 표준 ApprovalRequest로 결재 큐에 전달된다.",
    "audience": "사업 승인자/심사 담당자, 감사",
    "actors": ["act-roster-approver", "act-auditor"],
    "layout": "ConsoleNavRail + SessionActorBadge + AuthorityScopeBadge + OperationPlanPanel + RosterBuilderPanel + ApprovalPolicyPicker + ApproverSelector",
    "components": [
      "ConsoleNavRail",
      "SessionActorBadge",
      "AuthorityScopeBadge",
      "PermissionGate",
      "OperationPlanPanel",
      "RosterBuilderPanel",
      "ApprovalPolicyPicker",
      "ApproverSelector",
      "AccessibleStatusRow"
    ],
    "states": [
      { "state": "default", "description": "승인 정책 선택 및 OperationPlan 작성 대기" },
      { "state": "empty", "description": "조건에 맞는 후보 대상자 또는 업로드 명부가 없다." },
      {
        "state": "loading",
        "description": "승인 정책 조회, 행정속성 평가, 업로드 검증, 결재 상신 중이다."
      },
      {
        "state": "error",
        "description": "정책 미승인, OperationPlan 미작성, 동의근거 누락, 중복, 유통 단위 불일치, 결재선 누락을 표시한다."
      },
      {
        "state": "success",
        "description": "OperationPlan 작성 또는 후보 명부 결재 요청이 완료된다."
      }
    ],
    "copy": [
      { "key": "title", "text": "대상 명부 확정 · 운영계획서(OperationPlan)" },
      {
        "key": "payoutMethodReadOnly",
        "text": "정책 지급 방식은 PolicyCondition에서 정해져요. 이 화면에서는 수령 동의 방식만 정합니다"
      },
      { "key": "confirmCta", "text": "후보 명부 확정 · 결재 요청" }
    ],
    "dataNeeds": [
      "Approved Policy(policyRef, approvalStatus='approved', lifecycleStatus='active', executionStatus:executable|blocked, disabledReason?)",
      "PolicyCondition(conditionRef, payoutMethod:direct-grant|point-of-sale-discount|post-purchase-payback)",
      "OperationPlanDraft(operationPlanId?, policyRef, rosterSourceMode, payoutAcceptanceMode, authorIdentity, authorTitle, createdAt)",
      "CandidateRosterDraft(rosterId?, citizenId, circulationUnitId, consentRecordId, exclusionReason)",
      "ApprovalPolicy(appliesTo='policy-approval', approvalStatus='active'); roster-approval은 sourceAction/sourceActionAliases/sourceScreenId로만 보존",
      "ApprovalRequest payload(requester identity/title/jurisdiction, approvalPolicyRef, approverAssignments, signerBindings, sodPolicyResult opt-in, sourceScreenId='admin-roster-builder', sourceAction='roster-approval', sourceActionAliases:['roster-approval'], approvalContext{operationPlanDraft,rosterDraft,policyRef}, onFinalApproved.actionRefs structured array)"
    ]
