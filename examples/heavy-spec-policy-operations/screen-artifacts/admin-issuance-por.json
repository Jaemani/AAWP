  "interactions": {
    "affordances": [
      {
        "id": "admin-issuance-por.filter",
        "element": "ProofOfReserveRegistry(filter)",
        "trigger": "input",
        "action": "setLocalState",
        "target": "porFilter",
        "storeEffect": "none",
        "expected": "운용사·PoR 방식 필터 적용",
        "resolution": { "kind": "demo-state", "target": "porFilter" }
      },
      {
        "id": "admin-issuance-por.pickApprovalPolicy",
        "element": "ApprovalPolicyPicker(appliesTo=policy-approval, consoleSurface=issuer)",
        "trigger": "tap",
        "action": "setLocalState",
        "target": "selectedIssuerApprovalPolicy",
        "storeEffect": "none",
        "expected": "appliesTo='policy-approval', consoleSurface='issuer', grantedByRoot='act-issuer-principal'인 issuer 전용 결재정책만 선택하고 sourceAction=por-method-or-reserve-match로 기록한다",
        "resolution": { "kind": "demo-state", "target": "selectedIssuerApprovalPolicy" }
      },
      {
        "id": "admin-issuance-por.requestMethodChange",
        "element": "ProofOfReserveRegistry(changeMethodCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "por-method-change-request",
        "storeEffect": "reserveProof.registerReserveMatch(porChangeDraft, author, {approvalPolicyRef:selectedIssuerApprovalPolicy.id, approverAssignments:selectedApprovers, consoleSurface:'issuer', grantedByRoot:'act-issuer-principal', changeType:'por-method-or-reserve-match', sourceScreenId:'admin-issuance-por', sourceAction:'por-method-or-reserve-match', onFinalApproved:{actionRefs:[{slice:'reserveProof',action:'applyApprovedReserveMatch',args:{changeId:'$subjectRef',approvalId:'$approvalId'},idempotencyKey:'apply-por-method:$subjectRef:$approvalId',onlyWhen:{approvalStatus:'approved',quorumSatisfied:true}}]}, idempotencyKey})",
        "expected": "reserveProof.registerReserveMatch가 PoR 방식 또는 준비금 매칭 변경 draft와 issuer 전용 결재 요청을 1회 생성한다. 화면은 approvals.submitForApproval을 별도로 호출하지 않는다. 승인자 신원·직책·관할·일시가 결재 기록에 남는다",
        "resolution": { "kind": "demo-state", "target": "por-method-change-request" }
      },
      {
        "id": "admin-issuance-por.sign",
        "element": "SignerIdentityBinder",
        "trigger": "tap",
        "action": "submit",
        "target": "por-method-change-sign",
        "storeEffect": "approvals.signApproval(requestId, signerIdentity, decision='approve')",
        "expected": "단계 승인만 기록한다. 최종 결재 및 정족수 충족 시 backend approval runner가 approvals.runOnFinalApprovedOnce(requestId,{idempotencyKey:approvalRequest.onFinalApproved.idempotencyKey})를 호출해 porMethod 또는 준비금 매칭 변경을 한 번만 발효한다",
        "resolution": { "kind": "demo-state", "target": "por-method-change-sign" }
      },
      {
        "id": "admin-issuance-por.reject",
        "element": "ApprovalChainStepper(reject)",
        "trigger": "tap",
        "action": "submit",
        "target": "por-method-change-reject",
        "storeEffect": "approvals.rejectRequest(requestId, signerIdentity, reason)",
        "expected": "PoR 방식 변경 요청 반려, 반려 사유와 반려자 신원·직책·일시 기록",
        "resolution": { "kind": "demo-state", "target": "por-method-change-reject" }
      },
      {
        "id": "admin-issuance-por.recordVerification",
        "element": "ProofOfReserveRegistry(recordVerificationCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "por-verification-record",
        "storeEffect": "reserveProof.verifyOffchainCertificate(reserveId, certificateRef, verifierIdentity)",
        "expected": "오프체인 증명서 검증 결과와 검증자 신원·직책·일시 기록",
        "resolution": { "kind": "demo-state", "target": "por-verification-record" }
      },
      {
        "id": "admin-issuance-por.syncOnchain",
        "element": "ProofOfReserveRegistry(syncOnchainCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "por-oracle-sync",
        "storeEffect": "reserveProof.verifyOnchainOracle(reserveId, oracleRef, verifierIdentity)",
        "expected": "오라클 증빙 준비금의 txHash·contractRef·검증 결과 갱신. 준비자산 자체의 onchainCustodyRef나 지갑 보관 정보를 만들지 않는다",
        "resolution": { "kind": "demo-state", "target": "por-oracle-sync" }
      },
      {
        "id": "admin-issuance-por.backToReserves",
        "element": "AccessibleStatusRow(backToReserves)",
        "trigger": "tap",
        "action": "navigate",
        "target": "admin-issuance-reserves",
        "storeEffect": "none",
        "expected": "준비자산 관리로 이동",
        "resolution": { "kind": "selected-screen", "screenId": "admin-issuance-reserves" }
      }
    ],
    "reachableStates": [
