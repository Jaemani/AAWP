    "copy": [
      { "key": "title", "text": "준비금 증빙(PoR) 관리" },
      {
        "key": "authorityBadge",
        "text": "판정 근거이며 원장 아님. 권위 잔고는 보관기관 기록과 발행 원장이에요"
      },
      { "key": "methodOnchain", "text": "오라클 증빙" },
      { "key": "methodOffchain", "text": "오프체인 증명서" },
      { "key": "recordVerificationCta", "text": "증명서 검증 결과 기록" },
      { "key": "syncOnchainCta", "text": "오라클 동기화" },
