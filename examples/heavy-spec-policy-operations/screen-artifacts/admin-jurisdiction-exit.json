  "interactions": {
    "affordances": [
      {
        "id": "admin-jurisdiction-exit.updateEligibility",
        "element": "JurisdictionExitPanel(updateEligibilityCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "jurisdiction-eligibility-update",
        "storeEffect": "jurisdictionExit.updateEligibilityStatus({exitCaseId,citizenId,fromCirculationUnitId,newAffiliationStatus,effectiveAt,operatorIdentity,operatorTitle})",
        "expected": "자격/소속 상태만 갱신한다. 유통 단위 간 이전은 생성하지 않는다.",
        "resolution": { "kind": "demo-state", "target": "jurisdiction-eligibility-update" }
      },
      {
        "id": "admin-jurisdiction-exit.selectOutcome",
        "element": "JurisdictionExitPanel(outcomeSelector)",
        "trigger": "tap",
        "action": "setLocalState",
        "target": "selectedExitOutcome",
        "storeEffect": "none",
        "expected": "recover, redeem, continue-use 중 하나를 선택한다.",
        "resolution": { "kind": "demo-state", "target": "selectedExitOutcome" }
      },
      {
        "id": "admin-jurisdiction-exit.configureClosureApproval",
        "element": "ApprovalPolicyPicker+ApproverSelector",
        "trigger": "tap",
        "action": "setLocalState",
        "target": "exitClosureApprovalDraft",
        "storeEffect": "none",
        "expected": "appliesTo='settlement-exception', sourceAction='jurisdiction-exit.close'로 결재정책과 승인자를 선택한다.",
        "resolution": { "kind": "demo-state", "target": "exitClosureApprovalDraft" }
      },
      {
        "id": "admin-jurisdiction-exit.recoverPolicyFund",
        "element": "JurisdictionExitPanel(executeRecoverCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "policy-fund-recover-approval",
        "storeEffect": "approvals.submitForApproval({subjectType:'jurisdictionExitClosure',subjectRef:exitCaseId,sourceScreenId:'admin-jurisdiction-exit',sourceAction:'jurisdiction-exit.close',sourceActionAliases:['jurisdiction-exit'],requester:{identity:operatorIdentity,title:operatorTitle,jurisdiction},appliesTo:'settlement-exception',approvalPolicyRef,approverAssignments,signerBindings,sodPolicyResult,approvalContext:{citizenId,fromCirculationUnitId,policyRef,fundSourceType:'policyFund',selectedOutcome:'recover'},onFinalApproved:{actionRefs:[{slice:'jurisdictionExit',action:'closeExitCase',args:{exitCaseId:'$subjectRef',selectedOutcome:'recover',citizenId:'$approvalContext.citizenId',fromCirculationUnitId:'$approvalContext.fromCirculationUnitId',authorityRecordRefs:'create-from-closeExitCase',approvalId:'$approvalId',executorIdentity:'$finalApproverIdentity',executorTitle:'$finalApproverTitle',executedAt:'$approvedAt',finalStatus:'closed'},idempotencyKey:'exit-recover:$subjectRef:$approvalId',onlyWhen:{approvalStatus:'approved',quorumSatisfied:true}}]}})",
        "expected": "manual-required 정책자금 회수는 결재 완료 후 closeExitCase가 회수 권위 기록을 생성하고 종결한다.",
        "resolution": { "kind": "demo-state", "target": "policy-fund-recover-approval" }
      },
      {
        "id": "admin-jurisdiction-exit.redeemRemainingBalance",
        "element": "JurisdictionExitPanel(redeemOutcomeCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "jurisdiction-redeem-outcome",
        "storeEffect": "approvals.submitForApproval({subjectType:'jurisdictionExitClosure',subjectRef:exitCaseId,sourceScreenId:'admin-jurisdiction-exit',sourceAction:'jurisdiction-exit.close',sourceActionAliases:['jurisdiction-exit'],requester:{identity:operatorIdentity,title:operatorTitle,jurisdiction},appliesTo:'settlement-exception',approvalPolicyRef,approverAssignments,signerBindings,sodPolicyResult,approvalContext:{citizenId,fromCirculationUnitId,selectedOutcome:'redeem'},onFinalApproved:{actionRefs:[{slice:'jurisdictionExit',action:'closeExitCase',args:{exitCaseId:'$subjectRef',selectedOutcome:'redeem',citizenId:'$approvalContext.citizenId',fromCirculationUnitId:'$approvalContext.fromCirculationUnitId',authorityRecordRefs:'create-from-closeExitCase',approvalId:'$approvalId',executorIdentity:'$finalApproverIdentity',executorTitle:'$finalApproverTitle',executedAt:'$approvedAt',finalStatus:'closed'},idempotencyKey:'exit-redeem:$subjectRef:$approvalId',onlyWhen:{approvalStatus:'approved',quorumSatisfied:true}}]}})",
        "expected": "상환 선택은 출발 유통 단위의 ConvertibilityRule과 목적별 PooledAccount를 근거로 종결한다. 다른 유통 단위로 잔액을 이전하지 않는다.",
        "resolution": { "kind": "demo-state", "target": "jurisdiction-redeem-outcome" }
      },
      {
        "id": "admin-jurisdiction-exit.continueUse",
        "element": "JurisdictionExitPanel(continueUseOutcomeCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "jurisdiction-continue-use-outcome",
        "storeEffect": "jurisdictionExit.closeExitCase({exitCaseId,selectedOutcome:'continue-use',citizenId,fromCirculationUnitId,authorityRecordRefs:'create-from-closeExitCase',approvalNotRequiredReason:'policy-allows-continue-use',executorIdentity:operatorIdentity,executorTitle:operatorTitle,executedAt,finalStatus:'closed'})",
        "expected": "계속사용도 처리자 신원·직책·일시와 authorityRecordRefs를 남겨 종결한다.",
        "resolution": { "kind": "demo-state", "target": "jurisdiction-continue-use-outcome" }
      }
    ],
