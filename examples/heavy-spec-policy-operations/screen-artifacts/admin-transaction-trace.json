  "interactions": {
    "affordances": [
      {
        "id": "admin-transaction-trace.filter",
        "element": "SearchField+TransactionTraceTable(filter)",
        "trigger": "input",
        "action": "setLocalState",
        "target": "traceFilter",
        "storeEffect": "none",
        "expected": "지갑/가맹점/기간/유통단위/상품권/판정상태/sourceStandard='ISO18245'/UNSPSC 필터를 적용한다.",
        "resolution": { "kind": "demo-state", "target": "traceFilter" }
      },
      {
        "id": "admin-transaction-trace.rowDetail",
        "element": "TransactionTraceTable(row)",
        "trigger": "tap",
        "action": "openSheet",
        "target": "transaction-detail-sheet",
        "storeEffect": "none",
        "expected": "거래ID, 금액, sub-settlement, 상품권 차감, 표준 코드, payoutMethod, txHash를 read-only 표시한다.",
        "resolution": { "kind": "demo-state", "target": "transaction-detail-sheet" }
      }
    ],
    "reachableStates": [
