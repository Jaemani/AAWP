  "interactions": {
    "affordances": [
      {
        "id": "admin-settlement-batch.runBatch",
        "element": "SettlementBatchRunPanel(runBatchCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "settlement-batch-run",
        "storeEffect": "settlementAdmin.runSettlementBatch(batchId,{circulationUnitId,period,operatorIdentity,operatorTitle,requestedAt,approvalId})",
        "expected": "결재 완료된 배치만 backend settlement workflow에 접수한다. 각 항목은 circulationUnitId와 subSettlementId 안에서 종결된다.",
        "resolution": { "kind": "demo-state", "target": "settlement-batch-run" }
      },
      {
        "id": "admin-settlement-batch.recordPostPurchasePaybackBatch",
        "element": "SettlementBatchRunPanel(recordPaybackCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "post-purchase-payback-record-batch",
        "storeEffect": "settlementAdmin.requestPostPurchasePayback({transactionId,citizenId,amount,policyRef,triggerMode:'batch-schedule',supervisedBy:operatorIdentity,circulationUnitId,subSettlementId,targetPooledAccountRef})",
        "expected": "완료 거래와 승인된 post-purchase-payback 정책을 근거로 backend workflow가 권위 기록을 생성한다.",
        "resolution": { "kind": "demo-state", "target": "post-purchase-payback-record-batch" }
      },
      {
        "id": "admin-settlement-batch.configureManualPaybackApproval",
        "element": "ApprovalPolicyPicker+ApproverSelector",
        "trigger": "tap",
        "action": "setLocalState",
        "target": "manualPaybackApprovalDraft",
        "storeEffect": "none",
        "expected": "appliesTo='settlement-exception', sourceAction='settlement-batch.manual-payback'의 승인자 후보, 결재선, signerBindings를 구성한다.",
        "resolution": { "kind": "demo-state", "target": "manualPaybackApprovalDraft" }
      },
      {
        "id": "admin-settlement-batch.recordPostPurchasePaybackManual",
        "element": "SettlementBatchRunPanel(manualPaybackRow)",
        "trigger": "tap",
        "action": "submit",
        "target": "post-purchase-payback-record-manual",
        "storeEffect": "approvals.submitForApproval({subjectType:'postPurchasePayback',subjectRef:transactionId,sourceScreenId:'admin-settlement-batch',sourceAction:'settlement-batch.manual-payback',sourceActionAliases:['settlement-batch'],requester:{identity:operatorIdentity,title:operatorTitle,jurisdiction},appliesTo:'settlement-exception',approvalPolicyRef,approverAssignments,signerBindings,sodPolicyResult,approvalContext:{transactionId,policyRef,circulationUnitId,subSettlementId,targetPooledAccountRef},onFinalApproved:{actionRefs:[{slice:'settlementAdmin',action:'recordManualPostPurchaseRefund',args:{exceptionId:'$subjectRef',payload:{transactionId:'$subjectRef',policyRef:'$approvalContext.policyRef',circulationUnitId:'$approvalContext.circulationUnitId',subSettlementId:'$approvalContext.subSettlementId',targetPooledAccountRef:'$approvalContext.targetPooledAccountRef',approvalId:'$approvalId'}},idempotencyKey:'manual-payback:$subjectRef:$approvalId',onlyWhen:{approvalStatus:'approved',quorumSatisfied:true}}]}})",
        "expected": "수동 사후 환급은 결재 요청만 생성한다. 권위 기록은 최종 승인 조건 충족 뒤 approvals.runOnFinalApprovedOnce에서 한 번만 생성된다.",
        "resolution": { "kind": "demo-state", "target": "post-purchase-payback-record-manual" }
      }
    ],
    "reachableStates": [
      { "state": "default", "via": "배치/후보 조회" },
      { "state": "loading", "via": "실행 또는 기록 생성 중" },
