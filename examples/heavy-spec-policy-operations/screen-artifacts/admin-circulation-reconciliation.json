  "interactions": {
    "affordances": [
      {
        "id": "admin-circulation-reconciliation.verifyLiabilityCommit",
        "element": "ReconciliationPanel(verifyCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "liability-proof-verify",
        "storeEffect": "circulation.verifyLiabilityCommit(circulationUnitId,{method,batchCommitRef,liabilityProofRef,verifierIdentity,verifierTitle,verifiedAt})",
        "expected": "액션 내부에서 units[].internalLedgerRef를 조회해 검증된 liabilitySum, batchCommitRef, liabilityProofRef, lastVerifiedAt, reconcileStatus만 갱신한다.",
        "resolution": { "kind": "demo-state", "target": "liability-proof-verify" }
      },
      {
        "id": "admin-circulation-reconciliation.runReconciliation",
        "element": "ReconciliationPanel(runReconciliationCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "circulation-reconciliation-run",
        "storeEffect": "circulation.runReconciliation(circulationUnitId,{period,operatorIdentity,operatorTitle,runAt})",
        "expected": "InternalLedger 부채 합계와 PooledAccount 재원 충분성을 분리 계산한다. 유통 단위 간 netting은 만들지 않는다.",
        "resolution": { "kind": "demo-state", "target": "circulation-reconciliation-run" }
      },
      {
        "id": "admin-circulation-reconciliation.openWalletProvisioningStatus",
        "element": "OnchainWalletProvisioningPanel",
        "trigger": "tap",
        "action": "openSheet",
        "target": "wallet-provisioning-status-sheet",
        "storeEffect": "none",
        "expected": "providerRef, chain, custodyType, returnedAddress, provisioningRecordRef, status pending|provisioning|provisioned|failed, failureReason, retryCount를 read-only로 표시한다.",
        "resolution": { "kind": "demo-state", "target": "wallet-provisioning-status-sheet" }
      },
      {
        "id": "admin-circulation-reconciliation.signOff",
        "element": "SignerIdentityBinder(signOffCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "circulation-signoff",
        "storeEffect": "circulation.signOffReconciliation({circulationUnitId,auditorIdentity,auditorTitle,jurisdiction,signedAt})+auditLog.append({origin:'admin-circulation-reconciliation',circulationUnitId,auditorIdentity,auditorTitle,signedAt})",
        "expected": "감사자 신원·직책·관할·일시를 기록한다.",
        "resolution": { "kind": "demo-state", "target": "circulation-signoff" }
      },
