    "dataNeeds": [
      "InternalLedger(internalLedgerId, circulationUnitId, liabilitySum, batchCommitRef, liabilityProofRef, reserveProofRef, onchainWalletRef{chain,address,custodyType,provisionedBy:'system',providerRef,provisioningRecordRef,provisioningStatus:pending|provisioning|provisioned|failed,custodyMandateRef,keyControlPolicyRef}, reconcileStatus, lastVerifiedAt)",
