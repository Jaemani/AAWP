      },
      {
        "key": "statusNote",
        "text": "정책 작성에서는 게시 완료·승인 완료 조건 세트만 선택할 수 있어요."
      },
      { "key": "saveCta", "text": "조건 세트로 저장" },
      {
        "key": "successMsg",
        "text": "조건 세트가 저장됐어요. 승인·게시가 끝나면 정책 작성에서 선택할 수 있어요."
      }
    ],
    "dataNeeds": [
      "EligibilityConditionSet(setId prefix ecs-*·conditionSetStatus draft|published|retired·approvalStatus approved|pending|rejected|expired·predicateTree·referencedAttributes·author identity/title·createdAt·approvalId?)",
      "UsageConditionSet(setId prefix ucs-*·conditionSetStatus draft|published|retired·approvalStatus approved|pending|rejected|expired·사용지역·사용기간·구매한도·merchantCategoryCodeRefs[]=ISO18245 4자리·itemCategoryCodeRefs[]=UNSPSC standardCode·payoutMethod direct-grant|point-of-sale-discount|post-purchase-payback·posDiscountSettlementCycle?·targetPooledAccountRef?·postPurchasePaybackTriggerMode batch-schedule|manual-approval·approvalId?·circulationScope?)",
      "MerchantCategoryCode active 목록(code·displayCode='ISO 18245 {code}'·label·sourceStandard='ISO18245')",
      "ItemCategoryCode active 목록(code·standardCode·label·sourceStandard='UNSPSC')",
      "참고 집계(예상 대상 규모)"
    ]
  },
