  "screen": {
    "id": "admin-condition-builder",
    "route": "/admin/policy/conditions",
    "surface": "관리 콘솔(웹)",
    "title": "조건 빌더 — 대상 조건 · 사용 조건",
    "purpose": "대상 조건과 사용 조건을 공통 빌더 UI에서 작성해 재사용 조건 세트로 저장한다. 저장 ref는 EligibilityConditionSet은 ecs-*, UsageConditionSet은 ucs-* 네임스페이스를 사용한다. 허용업종은 merchantCategoryCodeRefs[]=ISO 18245 4자리 MerchantCategoryCode.code로, 품목분류는 itemCategoryCodeRefs[]=UNSPSC ItemCategoryCode.code로만 저장한다. payoutMethod는 direct-grant, point-of-sale-discount, post-purchase-payback 중 하나로 저장하며 사용자 노출 카피는 사후 환급으로 통일한다. 정책 작성 화면은 conditionSetStatus='published' && approvalStatus='approved'인 조건 세트만 선택할 수 있다.",
    "audience": "정책조건 등록자 · 정책총괄·책임관",
    "actors": ["act-policy-operator", "act-policy-approver"],
    "layout": "상단 chrome + 좌측 탭(대상 조건/사용 조건) + 중앙 조건 빌더 캔버스 + 우측 표준 코드 선택 패널/예상 규모 참고 집계 + 하단 저장된 조건 세트 목록",
    "components": [
      "ConsoleNavRail",
      "SessionActorBadge",
      "AuthorityScopeBadge",
      "EligibilityRuleBuilder",
      "PolicyConditionBinder",
      "PermissionGate",
      "AccessibleStatusRow",
      "AuditTrailRow"
    ],
    "states": [
      {
        "state": "default",
        "description": "대상/사용 조건 탭과 빌더 캔버스, 저장된 조건 세트 목록을 표시한다. 조건 세트 목록은 conditionSetStatus와 approvalStatus를 별도 배지로 표시한다."
      },
      { "state": "empty", "description": "저장된 조건 세트가 없어 최초 조건 작성을 안내한다." },
      { "state": "loading", "description": "조건 저장/참고 집계 계산 중이다." },
      {
        "state": "error",
        "description": "PII 동의근거 미확인 속성 추가, 비활성 표준 코드 선택, payoutMethod별 필수 정산 입력 누락 등 검증 실패를 표시한다."
      },
      {
        "state": "success",
        "description": "조건 세트 저장 완료 후 작성자 신원·직책/역할·일시를 기록한다. 승인·게시 전에는 정책 작성 picker에 노출하지 않는다."
      }
    ],
    "copy": [
      { "key": "title", "text": "조건 빌더" },
