  "screen": {
    "id": "admin-issuance-execute",
    "route": "/issuer/issuance/plans/:planId/execute",
    "surface": "발행사 콘솔(웹)",
    "title": "발행 실행 · mint 집행",
    "purpose": "결재 완료된 발행 계획의 mint를 집행하는 권위 화면. 발행 인가, licenseStatus, 승인된 InstrumentClassificationMapping, legalBasisStatus, 준비자산, 발행한도, issuerSession step-up, masterMinter 온체인 서명을 모두 충족해야 mint가 확정된다. 실행 결과는 발행 원장에 기록되며 소비자 잔액 projection이나 유통 단위 InternalLedger를 직접 수정하지 않는다.",
    "audience": "발행 관리자 · 온체인 발행 통제자(masterMinter)",
    "actors": ["act-issuance-manager", "act-master-minter"],
    "layout": "IssuerConsoleNavRail, 계획 요약, ReserveBackingPanel, IssuanceExecutionPanel, AdminAuthPanel step-up variant, SignerIdentityBinder masterMinter, LedgerTable preview",
    "components": [
      "IssuerConsoleNavRail",
      "SessionActorBadge",
      "AuthorityScopeBadge",
      "PermissionGate",
      "IssuanceExecutionPanel",
      "ReserveBackingPanel",
      "SignerIdentityBinder",
      "AdminAuthPanel",
      "LedgerTable",
      "AuditTrailRow",
      "AccessibleStatusRow"
    ],
    "states": [
      { "state": "default", "description": "결재 완료 계획의 실행 전 체크 대기" },
      {
        "state": "loading",
        "description": "발행 인가·상품 지원 상태·준비자산 재확인, step-up, masterMinter 서명, mint 처리 중"
      },
      { "state": "empty", "description": "실행 가능한 결재 완료 계획 없음" },
      {
        "state": "error",
        "description": "결재 미완료, 인가 만료·정지, 상품 분류 미지원, 법적 근거 미승인, 준비자산 부족, step-up 실패, masterMinter 서명 실패"
      },
      { "state": "success", "description": "mint 완료 및 발행 원장 반영" }
    ],
    "copy": [
      { "key": "title", "text": "발행 실행" },
      { "key": "authorityBadge", "text": "mint 결과는 발행 원장에 기록돼요" },
      {
        "key": "authorizationGate",
        "text": "발행 인가가 유효하고 이 상품 분류에서 mint가 허용된 경우에만 실행할 수 있어요"
      },
      {
        "key": "legalBasisGate",
        "text": "상품 분류의 법적 근거가 승인되지 않았거나 launchBlocked 상태이면 실행할 수 없어요"
      },
      {
        "key": "masterMinterGate",
        "text": "masterMinter 서명은 발행총량 통제 권한이며 유통 단위 온체인 지갑 참조가 아니에요"
      },
      { "key": "executeCta", "text": "mint 실행" },
      {
        "key": "resultLabel",
        "text": "mintTxID · txHash · keyRef · signedAt · onchainApprovalRef"
      },
      { "key": "successMsg", "text": "발행이 실행됐어요" }
    ],
    "dataNeeds": [
      "approved IssuancePlan(planId uses ip-* prefix, approvalId, approvalStatus=approved, issuerRef, issuerAuthorizationRef uses iauth-* prefix, licenseRef, instrumentClassificationMappingRef, circulationUnitIds, supplyAmount, burnSettlementPolicyRef)",
      "IssuerAuthorization validation(issuerAuthorizationRef uses iauth-* prefix, issuerRef, authorizationType, instrumentClassification, licenseStatus=valid, validity{validFrom,validUntil}, auditBasis, status=active)",
      "InstrumentClassificationMapping(mappingId, mappingVersion, approvalStatus=approved, licenseStatus=valid, legalBasisPolicyRef, legalBasisStatus=approved, productSupportMatrix.mint=true, launchBlocked=false)",
      "productSupportMatrix boolean map exactly: topup, exchange, payQr, accountWithdrawal, p2pTransfer, mint, burn; blockedReason only when launchBlocked=true",
      "ReserveBacking final check from off-chain reserve assets only",
      "issuanceLimit headroom",
      "issuerSession stepUp result(consoleSurface=issuer)",
      "masterMinter signature(keyRef, signedAt, onchainApprovalRef)",
      "mint result(mintTxID, txHash, ledgerStatus)"
    ]
  },
  "sourceContracts": {
    "path": "source-contracts.json",
    "contentDigest": "0152d6efc3912fd35c57115816c0c1863f4d211720c0a2a8c84c8a8f2fb55660",
    "componentNames": [
      "IssuerConsoleNavRail",
      "SessionActorBadge",
      "AuthorityScopeBadge",
      "PermissionGate",
      "IssuanceExecutionPanel",
      "ReserveBackingPanel",
      "SignerIdentityBinder",
      "AdminAuthPanel",
      "LedgerTable",
      "AuditTrailRow",
      "AccessibleStatusRow"
    ]
  },
  "renderer": {
    "adapterId": "aawp-console-surface",
    "adapterVersion": "0.1.0",
    "formFactor": "web"
  },
  "navigation": {
    "type": "nav-rail",
    "items": [
      {
        "label": "발행 계획",
        "target": "admin-issuance-plans",
        "icon": "file-text",
        "resolution": { "kind": "selected-screen", "screenId": "admin-issuance-plans" }
      },
      {
        "label": "발행 실행",
        "target": "admin-issuance-execute",
        "icon": "play-circle",
        "resolution": { "kind": "selected-screen", "screenId": "admin-issuance-execute" }
      },
      {
        "label": "발행 원장",
        "target": "admin-issuance-ledger",
        "icon": "book-open",
        "resolution": { "kind": "selected-screen", "screenId": "admin-issuance-ledger" }
      },
      {
        "label": "발행 한도",
        "target": "admin-issuance-limit",
        "icon": "gauge",
        "resolution": { "kind": "selected-screen", "screenId": "admin-issuance-limit" }
      },
      {
        "label": "준비자산",
        "target": "admin-issuance-reserves",
        "icon": "vault",
        "resolution": { "kind": "selected-screen", "screenId": "admin-issuance-reserves" }
      },
      {
        "label": "대사",
        "target": "admin-backing-reconciliation",
        "icon": "scale",
        "resolution": { "kind": "selected-screen", "screenId": "admin-backing-reconciliation" }
      },
      {
        "label": "공급 소각·정산",
        "target": "admin-supply-burn-settlement",
        "icon": "flame",
        "resolution": { "kind": "selected-screen", "screenId": "admin-supply-burn-settlement" }
      }
    ]
  },
  "interactions": {
    "affordances": [
      {
        "id": "admin-issuance-execute.recheck",
        "element": "IssuanceExecutionPanel(recheck)",
        "trigger": "tap",
        "action": "submit",
        "target": "mint-prerequisite-check",
        "storeEffect": "issuance.verifyReserves(planId)+issuance.verifyIssuerAuthorization({operation:'mint', planId, issuerRef, issuerAuthorizationRef, licenseRef, instrumentClassificationMappingRef, circulationUnitIds:plan.circulationUnitIds})",
        "expected": "실행 직전 오프체인 준비자산, 발행가능한도, 발행주체 인가 status=active, licenseStatus=valid, authorizationType·instrumentClassification 적합성, InstrumentClassificationMapping.approvalStatus=approved, legalBasisStatus=approved, productSupportMatrix.mint=true를 표시한다. 원장 수정은 하지 않는다",
        "resolution": { "kind": "demo-state", "target": "mint-prerequisite-check" }
      },
      {
        "id": "admin-issuance-execute.stepUp",
        "element": "AdminAuthPanel(variant=step-up)",
        "trigger": "input",
        "action": "submit",
        "target": "issuer-step-up",
        "storeEffect": "issuerSession.stepUpReauth(actorId, {keyType:'issuer-console', purpose:'executeMint', planId})",
        "expected": "발행 관리자 신원 재확인 및 step-up 상태 저장. issuerSession owner가 consoleSurface=issuer로 기록한다",
        "resolution": { "kind": "demo-state", "target": "issuer-step-up" }
      },
      {
        "id": "admin-issuance-execute.masterMinterSign",
        "element": "SignerIdentityBinder(masterMinter)",
        "trigger": "tap",
        "action": "submit",
        "target": "onchain-mint-sign",
        "storeEffect": "issuance.signOnchainMint(planId, masterMinterId)",
        "expected": "masterMinter canOperate, onchainKeyBound=true, 정책상 온체인 게이트를 검증한 뒤 keyRef·signedAt·onchainApprovalRef 생성",
        "resolution": { "kind": "demo-state", "target": "onchain-mint-sign" }
      },
      {
        "id": "admin-issuance-execute.execute",
        "element": "IssuanceExecutionPanel(executeCta)",
        "trigger": "tap",
        "action": "submit",
        "target": "mint-execute",
        "storeEffect": "issuance.executeMint(planId, executorId, {stepUpRef, masterMinterSignatureRef})",
        "expected": "결재 완료, step-up, 발행 인가 유효, licenseStatus=valid, 상품 분류 mint 허용, legalBasisStatus=approved, 오프체인 준비자산 재확인, 발행한도, masterMinter 서명 충족 시 mintTxID·txHash를 발급하고 발행 원장에 실행자·승인결재ID·issuerAuthorizationRef·masterMinter 서명 참조 기록. InternalLedger.onchainWalletRef는 조회하지 않고 서명 권한으로도 쓰지 않는다",
        "resolution": { "kind": "demo-state", "target": "mint-execute" }
      },
      {
        "id": "admin-issuance-execute.viewLedger",
        "element": "IssuanceExecutionPanel(viewLedger)",
        "trigger": "tap",
        "action": "navigate",
        "target": "admin-issuance-ledger",
        "storeEffect": "none",
        "expected": "실행 완료 후 발행 원장 행으로 이동",
        "resolution": { "kind": "selected-screen", "screenId": "admin-issuance-ledger" }
      }
    ],
    "reachableStates": [
      { "state": "default", "via": "실행 전 체크 대기" },
      { "state": "loading", "via": "재확인·step-up·서명·mint 처리" },
      { "state": "empty", "via": "실행 가능 계획 없음" },
      { "state": "error", "via": "게이트 실패" },
      { "state": "success", "via": "mint 완료" }
    ]
  },
  "specFeedback": []
