  "screen": {
    "id": "admin-circulation-dashboard",
    "route": "/admin/circulation/dashboard",
    "surface": "관리 콘솔(웹)",
    "title": "유통 현황 · 유통 지갑",
    "purpose": "유통 단위별 집계 projection과 승인 후 시스템이 발급한 유통 단위 온체인 지갑 상태를 read-only로 모니터링한다.",
    "audience": "정책조건 등록자, 감사, 권한관리자",
    "actors": ["act-policy-operator", "act-auditor", "act-superadmin"],
    "layout": "ConsoleNavRail + SessionActorBadge + AuthorityScopeBadge + CirculationUnitPicker + CirculationWalletPanel + OnchainWalletProvisioningPanel(read-only) + InternalLedgerStatusPanel + PolicyEffectMetricCard",
    "components": [
      "ConsoleNavRail",
      "SessionActorBadge",
      "AuthorityScopeBadge",
      "PermissionGate",
      "CirculationUnitPicker",
      "CirculationWalletPanel",
      "OnchainWalletProvisioningPanel",
      "InternalLedgerStatusPanel",
      "PolicyEffectMetricCard",
      "AccessibleStatusRow"
    ],
    "states": [
      {
        "state": "default",
        "description": "유통 잔액 집계, 온체인 지갑 발급 상태, InternalLedger 상태, 연결 PooledAccount 목록 표시"
      },
      {
        "state": "loading",
        "description": "원장 집계, 지갑 발급 상태와 PooledAccount 목록 조회 중"
      },
      { "state": "empty", "description": "세션에 배정된 유통 단위가 없다." },
      {
        "state": "error",
        "description": "집계 조회 실패, 권한 밖, internalLedgerRef 누락, PooledAccount 참조 불일치 또는 provisioningRecordRef 누락을 표시한다."
      },
      { "state": "success", "description": "필터 또는 기간 변경 결과가 반영된다." }
    ],
    "copy": [
      { "key": "title", "text": "유통 현황 · 유통 지갑" },
      {
        "key": "aggregateBadge",
        "text": "집계 projection — 권위 원장이 아니라 as-of 기준 집계예요"
      },
      { "key": "walletProvisioningTitle", "text": "유통 단위 지갑 발급 상태" },
      {
        "key": "walletProvisioningReadOnly",
        "text": "지갑 provider·chain·custodyType은 플랫폼 승인 기준으로 시스템이 정한 결과입니다"
      },
      { "key": "closedBoundaryNote", "text": "유통 단위 간 이전·순결제는 만들지 않아요" }
    ],
    "dataNeeds": [
      "CirculationUnit(circulationUnitId, name, jurisdiction, type:province|city-county|institution, displayLabel, internalLedgerRef, pooledAccountRefs[])",
      "InternalLedger(internalLedgerId, circulationUnitId, liabilitySum, batchCommitRef, liabilityProofRef, reserveProofRef, onchainWalletRef{chain,address,custodyType,provisionedBy:'system',providerRef,provisioningRecordRef,provisioningStatus:pending|provisioning|provisioned|failed}, reconcileStatus, lastVerifiedAt)",
      "OnchainWalletProvisioningRecord(recordId, circulationUnitId, providerRef, providerType, returnedAddress, chain, custodyType, providerAuthorizationRef, custodyMandateRef, keyControlPolicyRef, externalMandateRef, legalBasisStatus, status:pending|provisioning|provisioned|failed, failureReason?, retryCount, idempotencyKey)",
      "CanonicalProviderAllowlist(providerRef, providerType:custody-provider|ledger-connector|oracle-endpoint, allowedChains[], allowedCustodyTypes[], defaultChain, defaultCustodyType, isDefault, defaultPriority, approvalPolicyRef, providerAuthorizationRef, custodyMandateRef, keyControlPolicyRef, externalMandateRef, legalBasisStatus, status='active') read-only",
      "PooledAccount(accountId, policyRef, fundNature:policyFund|reserveAsset|mixed, policyFundAccount?, customerFundsAccount?, reserveAssets[] 오프체인 예치·전통 수탁·평가금·증명 참조)",
      "topup requiredCustomerFundsAccount rule은 fundNature가 아니라 policyType='topup' 또는 accountPurpose='customerTopupPrincipal'로만 판정",
      "viewableCirculationUnitIds",
      "asOf 동기화 시각"
    ]
