      "variants": ["info", "warning", "error", "success", "blocked"],
      "states": ["default", "loading", "success", "empty", "error"]
    },
    {
      "name": "CirculationPolicyComposer",
      "purpose": "일반 정책의 발행 필요 여부, 조건 세트 ref, 회수 방법, 유통 단위·재원, 전환 정책을 단계형 폼으로 작성한다. 신규 유통 단위 입력은 명칭·관할·canonical type만 받으며 온체인 인프라 필드는 받지 않는다. 상품권 정책 설정은 VoucherPolicySetupPanel이 소유한다.",
      "props": [
        "composerStep",
        "policyDraft",
        "circulationUnitMode(reuse-existing|provision-new)",
        "selectedCirculationUnitId",
        "eligibilityConditionSetRef",
        "usageConditionSetRef",
        "conditionRefs",
        "conditionSetPreview",
