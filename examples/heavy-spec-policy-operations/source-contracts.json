  "components": [
    {
      "name": "ConsoleNavRail",
      "purpose": "관리 콘솔의 nav-rail을 렌더링하고 현재 surface membership과 grantedBy 체계에 따라 접근 가능한 화면만 표시한다. issuer surface는 별도 IssuerConsoleNavRail 또는 consoleSurface='issuer' 분기를 사용한다.",
      "props": [
        "surface(admin|issuer)",
        "activeScreenId",
        "items",
        "sessionActor",
        "grantedByRoot",
        "routeRegistry(admin|issuer)"
      ],
      "variants": ["admin-console", "issuer-console"],
      "states": ["default", "collapsed"]
    },
    {
      "name": "SessionActorBadge",
      "purpose": "현재 콘솔 세션의 actorId, 신원, 직책/역할, 관할, grantType, grantedByRoot, readOnly 상태를 표시한다. issuer surface는 act-issuer-principal grantedByRoot 계보를 분리 표시한다.",
      "props": [
        "actorId",
        "actorIdentity",
        "actorTitle",
        "roleGroup",
        "jurisdictionScope",
        "grantType",
        "grantedByRoot",
        "consoleSurface(admin|issuer)",
        "readOnly"
      ],
      "variants": ["admin", "issuer", "auditor"],
      "states": ["default", "readOnly"]
    },
    {
      "name": "AuthorityScopeBadge",
      "purpose": "화면 또는 행 단위 권위 범위가 authoritative, judgment-basis, projection 중 무엇인지 표시한다.",
      "props": ["authorityScope", "jurisdictionRef", "sourceScreenId"],
      "variants": ["authoritative", "judgment-basis", "projection"],
      "states": ["default"]
    },
    {
      "name": "PolicyLifecycleTable",
      "purpose": "정책 목록, lifecycleStatus, executionStatus, disabledReason, 만료·중지 결재 상태를 표로 표시한다. 만료는 lifecycle 전이만 수행한다. 상품권 정책은 policyKind='voucher-payout'으로만 구분하며 별도 유형 enum을 표시하지 않는다.",
      "props": [
        "policies",
        "columns",
        "filter",
        "selectedPolicyId",
        "policyKind",
        "policyName",
        "policyPurpose",
        "owningDepartment",
        "targetPooledAccountRef",
        "conditionRefsSummary",
        "payoutExecutionMode",
        "needsNewIssuanceProjection",
        "lifecycleStatus",
        "executionStatus(executable|blocked)",
        "disabledReason"
      ],
      "variants": ["active", "expired", "blocked", "read-only", "voucher-payout-list"],
      "states": ["default", "loading", "empty", "error"]
    },
    {
      "name": "ApprovalChainStepper",
      "purpose": "전자결재 단계, 승인/반려 결정, 정족수 충족 여부, 최종 후처리 상태를 표시한다.",
      "props": ["approvalSteps", "quorumSatisfied", "approvalStatus", "finalizerStatus"],
      "variants": ["horizontal", "vertical"],
      "states": ["default", "pending", "approved", "rejected"]
    },
    {
      "name": "AuditTrailRow",
      "purpose": "결재 단계, 승인/반려 결정, 승인자 신원·직책·일시, 결재ID, 권위 후처리 결과를 읽기 전용으로 표시한다.",
      "props": [
        "approvalSteps",
        "decision",
        "approvalId",
        "actorIdentity",
        "actorTitle",
        "decidedAt",
        "authorityActionRefs"
      ],
      "variants": ["summary", "sheet-row"],
      "states": ["default"]
    },
    {
      "name": "PermissionGate",
      "purpose": "세션 roleGroup, readOnly, jurisdictionScope, sourceScreenId를 기준으로 권위 CTA 활성화 여부와 차단 사유를 표시한다. SoD는 정책 opt-in 결과로만 표시하며 강제 기본값으로 취급하지 않는다.",
      "props": [
