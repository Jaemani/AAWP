        "validationErrors"
      ],
      "variants": ["create", "edit"],
      "states": ["default", "loading", "error", "valid"]
    },
    {
      "name": "PolicyConditionBinder",
      "purpose": "정책 작성 화면이 conditionSetStatus='published' && approvalStatus='approved'인 EligibilityConditionSet/UsageConditionSet ref만 선택·요약하도록 묶는다. 업종·품목 raw code는 직접 편집하지 않고 merchantCategoryCodeRefs/itemCategoryCodeRefs 기반 read-only preview로만 표시한다. 상품권 정책의 대상+금액 반복 행은 기존 conditionRefs[] item에 grantAmount를 결합해 표현하며, condition scope가 있으면 선택된 targetCirculationUnitId와 충돌하지 않아야 한다.",
      "props": [
        "conditionRefs[]",
        "conditionRefs[].conditionRef",
        "conditionRefs[].eligibilityConditionSetRef",
        "conditionRefs[].targetGroupRef",
        "conditionRefs[].targetSummary",
        "conditionRefs[].grantAmount",
        "eligibilityConditionSetRef",
        "usageConditionSetRef",
        "targetCirculationUnitId",
        "conditionSetPreview",
        "conditionSetPreview.circulationUnitScope",
        "conditionSetPreview.merchantCategoryCodeRefs[]",
        "conditionSetPreview.itemCategoryCodeRefs[]",
        "conditionSetStatus(draft|published|retired)",
        "approvalStatus(approved|pending|rejected|expired)",
        "selectableWhen=conditionSetStatus:published+approvalStatus:approved",
        "scopeValidation=conditionScopeAbsentOrMatchesTargetCirculationUnit",
        "editConditionSetDeeplink='admin-condition-builder'",
        "targetAmountRowsSummary",
        "validationErrors"
      ],
      "variants": ["eligibility", "usage", "combined", "target-amount-rows", "read-only-preview"],
      "states": ["default", "error", "valid"]
    },
    {
      "name": "InstrumentClassificationMappingPanel",
      "purpose": "승인된 상품분류 mapping, redeemEligibility, boolean productSupportMatrix 7개 키를 read-only gate로 확인한다. 발행 인가와 라이선스 상태는 issuerAuthorization 및 resolved regulatory gate projection에서 합성해 소비자 CTA에 전달한다.",
      "props": [
        "mappingId",
        "mappingRef",
        "mappingVersion",
        "classification",
