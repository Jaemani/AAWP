{
  "schemaVersion": "aawp/local-execution-manifest/v1",
  "workflowId": "spec-feedback-to-spec",
  "workingDirectory": ".",
  "steps": [
    {
      "nodeId": "compile-feedback",
      "command": [
        "node",
        "workflows/templates/spec-feedback-to-spec/dist/runner/compile-feedback.js"
      ],
      "timeoutSec": 60,
      "tokenTracking": "none",
      "outputs": [
        {
          "port": "contract",
          "source": "file",
          "path": "artifacts/spec-revision/contract.json",
          "base": "executionDirectory"
        }
      ]
    },
    {
      "nodeId": "propose-patch",
      "command": [
        "codex",
        "-a",
        "never",
        "exec",
        "--json",
        "--ephemeral",
        "--skip-git-repo-check",
        "--sandbox",
        "workspace-write",
        "--model",
        "gpt-5.5",
        "-c",
        "model_reasoning_effort=\"medium\"",
        "--cd",
        ".",
        "Execute the registered spec-feedback-to-spec propose-patch node. Read $AAWP_INPUT_PATH and workflows/templates/spec-feedback-to-spec/WORKFLOW.md completely, then follow them exactly. The only product inputs are the pinned source and feedback declared by the run contract. Write the patch proposal to $AAWP_EXECUTION_DIR/artifacts/spec-revision/patch-proposal.json. Do not merely describe the proposal."
      ],
      "timeoutSec": 1800,
      "tokenTracking": "required",
      "outputs": [
        {
          "port": "proposal",
          "source": "file",
          "path": "artifacts/spec-revision/patch-proposal.json",
          "base": "executionDirectory"
        }
      ]
    },
    {
      "nodeId": "materialize-revision",
      "command": [
        "node",
        "workflows/templates/spec-feedback-to-spec/dist/runner/materialize-revision.js"
      ],
      "timeoutSec": 120,
      "tokenTracking": "none",
      "outputs": [
        {
          "port": "candidate",
          "source": "file",
          "path": "artifacts/spec-revision/child-spec.candidate.json",
          "base": "executionDirectory"
        }
      ]
    },
    {
      "nodeId": "verify-revision",
      "command": [
        "node",
        "workflows/templates/spec-feedback-to-spec/dist/runner/verify-revision.js"
      ],
      "timeoutSec": 180,
      "tokenTracking": "none",
      "outputs": [
        {
          "port": "verdict",
          "source": "file",
          "path": "artifacts/spec-revision/revision-verdict.json",
          "base": "executionDirectory"
        },
        {
          "port": "gaps",
          "source": "file",
          "path": "artifacts/spec-revision/gap-report.json",
          "base": "executionDirectory"
        },
        {
          "port": "impact",
          "source": "file",
          "path": "artifacts/spec-revision/impact-report.json",
          "base": "executionDirectory"
        },
        {
          "port": "maturity",
          "source": "file",
          "path": "artifacts/spec-revision/maturity-verdict.json",
          "base": "executionDirectory"
        },
        {
          "port": "traceability",
          "source": "file",
          "path": "artifacts/spec-revision/traceability-report.json",
          "base": "executionDirectory"
        }
      ]
    }
  ]
}
